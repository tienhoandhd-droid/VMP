    {
      "parameters": {
        "jsCode": "const raw = $json.body;\nconst p = typeof raw === 'string' ? JSON.parse(raw) : raw;\n\nif (p.action === 'ping') return [{ json: { ok: true, pong: true, ts: Date.now() } }];\nif (p.action !== 'updateRow' || !p.id) throw new Error('Thiếu action=updateRow hoặc id');\n\nconst pt = p.patch || {};\nreturn [{ json: {\n  id: p.id, user: p.user || '', ts: p.ts || '',\n  ngay_de_cuong:  pt.ngay_de_cuong  ?? '',\n  tt_de_cuong:    pt.tt_de_cuong    ?? '',\n  lich_td:        pt.lich_td        ?? '',\n  ngay_tham_dinh: pt.ngay_tham_dinh ?? '',\n  tt_tham_dinh:   pt.tt_tham_dinh   ?? '',\n  ngay_bao_cao:   pt.ngay_bao_cao   ?? '',\n  tt_bao_cao:     pt.tt_bao_cao     ?? '',\n  ngay_vmp:       pt.ngay_vmp       ?? '',\n  tt_vmp:         pt.tt_vmp         ?? '',\n} }];"
      },
