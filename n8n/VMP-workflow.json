    {
      "parameters": {
        "jsCode": "function clean(s){ return String(s).replace(/\\s+/g, ' ').trim(); }\n\nconst rows = $input.all().map(({ json }) => {\n  const g = {};\n  for (const k of Object.keys(json)) g[clean(k)] = json[k];\n  const get = (h) => g[clean(h)] ?? '';\n  return {\n    id:             get('ID thẩm định'),\n    ma:             get('Mã đối tượng'),\n    ten:            get('Tên đối tượng'),\n    phan_loai:      get('Phân loại đối tượng'),\n    loai_td:        get('Loại thẩm định'),\n    bo_phan:        get('Bộ phận quản lý'),\n    khu_vuc:        get('Mã khu vực'),\n    line:           get('Line'),\n    show:           get('Show'),\n    td:             get('Thẩm định'),\n    tan_suat:       get('Tần suất thẩm định (tháng)'),\n    so_ngay_cong:   get('Số ngày công thẩm định thực tế'),\n    diem_trong_yeu: get('Điểm trọng yếu'),\n    nam:            get('Năm'),\n    qa:             get('QA phụ trách (QA nhập)'),\n    email_qa:       get('Email (QA nhập)'),\n    ns_khac:        get('Nhân sự bộ phận khác (Bộ phận khác nhập)'),\n    email_khac:     get('Email (Bộ phận khác nhập)'),\n    dl_de_cuong:    get('Deadline đề cương (T- 60 ngày)'),\n    ngay_de_cuong:  get('Thời gian thực tế hoàn thành đề cương'),\n    tt_de_cuong:    get('Trạng thái đề cương'),\n    dl_tham_dinh:   get('Deadline thẩm định thực tế (T-5-BC)'),\n    lich_td:        get('Bộ phận quản lý xếp lịch thẩm định (dd/mm/yyyy hh:mm:ss)'),\n    ngay_tham_dinh: get('Thời gian thực tế hoàn thành Thẩm định thực tế'),\n    tt_tham_dinh:   get('Trạng thái thẩm định thực tế'),\n    phan_loai_bc:   get('Phân loại báo cáo'),\n    dl_bao_cao:     get('Deadline báo cáo (T-5 ngày)'),\n    ngay_bao_cao:   get('Thời gian thực tế hoàn thành báo cáo'),\n    tt_bao_cao:     get('Trạng thái báo cáo'),\n    dl_vmp:         get('Deadline VMP (T)'),\n    ngay_vmp:       get('Thời gian thực tế Deadline VMP'),\n    tt_vmp:         get('Trạng thái VMP'),\n  };\n}).filter(r => r.ma);\n\nreturn [{ json: { ok: true, count: rows.length, rows } }];"
      },
